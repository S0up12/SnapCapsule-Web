# Copy this file to `.env` for local Docker Compose use, or set the same variables in Portainer/ZimaOS.
# Leave them blank to use the docker-compose defaults, or point them at custom host/NAS paths.
# Change FRONTEND_PORT or BACKEND_PORT if your server reports "port is already allocated".

# FRONTEND_PORT=3001
# BACKEND_PORT=8001
# DATABASE_DIR=/DATA/snapcapsule/DATAbase
# CACHE_DIR=/DATA/snapcapsule/cache
# IMPORTS_DIR=/DATA/snapcapsule/imports
# RAW_MEDIA_DIR=/DATA/snapcapsule/raw_media

FRONTEND_PORT=3000
BACKEND_PORT=8000
